<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yeni Yazı Ekle - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen py-8 px-4">
    <div class="max-w-3xl mx-auto bg-white rounded-lg shadow-sm border border-gray-200 p-8">
        <h1 class="text-2xl font-bold text-slate-800 mb-6">Yeni Blog Yazısı Oluştur</h1>
        <form action="/admin/new" method="POST" class="space-y-6">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Başlık</label>
                <input type="text" name="title" required placeholder="Örn: Nizip Merkez LED Tabela Kurulumu" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-yellow-500 focus:border-yellow-500">
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Kısa Özet</label>
                <input type="text" name="summary" required placeholder="Yazının kartlarda görünecek kısa bir tanıtımı..." class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-yellow-500 focus:border-yellow-500">
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Yazı İçeriği</label>
                <textarea name="content" required rows="10" placeholder="Yapılan tabelanın özellikleri, kullanılan malzemeler veya sektörel bilgilendirme yazısı..." class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-yellow-500 focus:border-yellow-500"></textarea>
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Görsel URL Adresi (İsteğe Bağlı)</label>
                <input type="url" name="image_url" placeholder="https://example.com/gorsel.jpg" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-yellow-500 focus:border-yellow-500">
            </div>
            <div class="flex justify-end space-x-3">
                <a href="/admin" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-5 py-2 rounded font-bold">Vazgeç</a>
                <button type="submit" class="bg-yellow-500 hover:bg-yellow-400 text-slate-900 px-5 py-2 rounded font-bold">Yazıyı Yayınla</button>
            </div>
        </form>
    </div>
</body>
</html>
