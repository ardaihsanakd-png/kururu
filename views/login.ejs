<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yönetici Girişi - Nizip Reklam</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-900 flex items-center justify-center min-h-screen px-4">
    <div class="bg-white p-8 rounded-lg shadow-xl w-full max-w-md">
        <div class="text-center mb-6">
            <h2 class="text-2xl font-bold text-slate-800">Yönetici Paneli</h2>
            <p class="text-gray-500 text-sm">Nizip Reklam Blog Yönetimi</p>
        </div>

        <% if (error) { %>
            <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-3 mb-4 text-sm"><%= error %></div>
        <% } %>

        <form action="/login" method="POST" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700">Kullanıcı Adı</label>
                <input type="text" name="username" required class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-yellow-500 focus:border-yellow-500">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Şifre</label>
                <input type="password" name="password" required class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-yellow-500 focus:border-yellow-500">
            </div>
            <button type="submit" class="w-full bg-slate-900 hover:bg-slate-850 text-white font-bold py-2 px-4 rounded transition">
                Giriş Yap
            </button>
        </form>
        <div class="mt-4 text-center">
            <a href="/" class="text-xs text-gray-500 hover:underline">&larr; Siteye Geri Dön</a>
        </div>
    </div>
</body>
</html>
