<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yönetici Paneli - Nizip Reklam</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">
    <!-- Üst Bar -->
    <nav class="bg-slate-900 text-white px-6 py-4 flex justify-between items-center shadow-md">
        <span class="font-bold text-yellow-500">Nizip Reklam Yönetim Paneli</span>
        <div class="flex items-center space-x-4">
            <span class="text-sm text-gray-300">Aktif Kullanıcı: <strong><%= username %></strong></span>
            <a href="/logout" class="bg-red-600 hover:bg-red-500 text-white px-3 py-1.5 rounded text-xs transition">Çıkış Yap</a>
        </div>
    </nav>

    <!-- Ana Panel İçeriği -->
    <main class="max-w-6xl mx-auto px-4 py-8">
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-2xl font-bold text-slate-800">Yazıları Yönet</h1>
            <a href="/admin/new" class="bg-yellow-500 hover:bg-yellow-400 text-slate-950 font-bold px-4 py-2 rounded shadow transition">Yeni Yazı Ekle</a>
        </div>

        <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Başlık</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Kısa Özet</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Oluşturulma Tarihi</th>
                        <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 bg-white">
                    <% if (posts.length === 0) { %>
                        <tr>
                            <td colspan="4" class="px-6 py-8 text-center text-gray-500">Henüz hiçbir yazı eklenmedi. İlk yazınızı ekleyerek başlayın!</td>
                        </tr>
                    <% } else { %>
                        <% posts.forEach(post => { %>
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-slate-900"><%= post.title %></td>
                                <td class="px-6 py-4 text-sm text-gray-500 truncate max-w-xs"><%= post.summary %></td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= new Date(post.created_at).toLocaleDateString('tr-TR') %></td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium flex justify-end space-x-2">
                                    <a href="/post/<%= post.slug %>" target="_blank" class="text-slate-600 hover:underline px-2">Görüntüle</a>
                                    <a href="/admin/edit/<%= post.id %>" class="text-blue-600 hover:underline px-2">Düzenle</a>
                                    <form action="/admin/delete/<%= post.id %>" method="POST" onsubmit="return confirm('Bu yazıyı silmek istediğinizden emin misiniz?');" class="inline">
                                        <button type="submit" class="text-red-600 hover:underline px-2">Sil</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>
